<mvc:View controllerName="zov.controller.View1" displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <VBox class="sapUiTinyMargin">
            <Label text="Última Ordem Criada"/>
            <Input text="" id="lastOrderId" editable="false"/>
            <TextArea id="textarea1" value="" rows="8" width="100%" editable="false"/>
        </VBox>
        <VBox class="sapUiTinyMargin">
            <Button text="Criar OV" press="onCreateOVCab"/>
            <Button text="Criar OV (Deep)" press="onCreateDeepOVCab"/>
            <Button text="Ler OV" press="onReadOVCab"/>
            <Button text="Atualizar OV" press="onUpdateOVCab"/>
            <Button text="Deletar OV" press="onDeleteOVCab"/>
        </VBox>
    </Page>
</mvc:View>
